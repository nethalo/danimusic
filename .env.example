# Copy to .env for local (non-docker) runs. Any Settings field is overridable.

DB_URL=mysql+pymysql://music:music@localhost:3306/musicdb
MB_USER_AGENT=DaniMusic/1.0 ( nethalo@gmail.com )

# Freshness window X (minutes) — governs fresh-serve for both cache and DB
FRESHNESS_MINUTES=10

# Vendor budget/retry/throttle
VENDOR_TIMEOUT_SECONDS=5
VENDOR_MAX_ATTEMPTS=2
OUTBOUND_MIN_INTERVAL_SECONDS=1

# Inbound rate limit (slowapi syntax)
INBOUND_RATE_LIMIT=30/minute

# Validation
GENRE_MAX_LENGTH=20
